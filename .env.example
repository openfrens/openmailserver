OPENMAILSERVER_ENV=development
OPENMAILSERVER_HOST=127.0.0.1
OPENMAILSERVER_PORT=8787
OPENMAILSERVER_DATA_DIR=./data
OPENMAILSERVER_LOG_DIR=./logs
OPENMAILSERVER_DATABASE_URL=postgresql+psycopg://openmailserver:openmailserver@127.0.0.1:5432/openmailserver
OPENMAILSERVER_FALLBACK_DATABASE_URL=sqlite+pysqlite:///./data/openmailserver.sqlite3
OPENMAILSERVER_DATABASE_SUPERUSER=postgres
OPENMAILSERVER_DATABASE_SUPERUSER_PASSWORD=
OPENMAILSERVER_MAILDIR_ROOT=./data/maildir
OPENMAILSERVER_ATTACHMENT_ROOT=./data/attachments
OPENMAILSERVER_CONFIG_ROOT=./runtime
OPENMAILSERVER_SMTP_HOST=127.0.0.1
OPENMAILSERVER_SMTP_PORT=25
OPENMAILSERVER_SMTP_TIMEOUT_SECONDS=15
OPENMAILSERVER_TRANSPORT_MODE=smtp
OPENMAILSERVER_CANONICAL_HOSTNAME=mail.example.com
OPENMAILSERVER_PRIMARY_DOMAIN=example.com
OPENMAILSERVER_PUBLIC_IP=203.0.113.10
OPENMAILSERVER_API_KEY_HEADER=X-OpenMailserver-Key
OPENMAILSERVER_LOG_FILE=./logs/openmailserver.log
OPENMAILSERVER_ADMIN_API_KEY=
OPENMAILSERVER_BACKUP_ENCRYPTION_KEY=
OPENMAILSERVER_MAX_SENDS_PER_HOUR=100
OPENMAILSERVER_MAX_MESSAGES_PER_MAILBOX=5000
OPENMAILSERVER_MAX_ATTACHMENT_BYTES=26214400
OPENMAILSERVER_DEBUG_API_ENABLED=true
OPENMAILSERVER_TELEMETRY=true
